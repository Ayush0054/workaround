# Copy to .dev.vars for local development (never commit .dev.vars).
# In production set these with: npx wrangler secret put <NAME>

# GitHub OAuth App credentials — GitHub App tokens cannot update arbitrary third-party stars.
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# 32+ random chars; generate with: openssl rand -base64 32
SESSION_SECRET=change_me_to_a_long_random_string

# --- Optional: AI review through Cloudflare AI Gateway ---
# Create a scoped token with AI Gateway Run access. Use the current REST
# chat-completions endpoint, not the deprecated /compat endpoint.
CLOUDFLARE_AI_GATEWAY_URL=https://api.cloudflare.com/client/v4/accounts/your_account_id/ai/v1/chat/completions
CLOUDFLARE_AI_API_TOKEN=
CLOUDFLARE_AI_GATEWAY_ID=default
CLOUDFLARE_AI_MODEL=openai/gpt-5.4-mini

# --- Optional fallback: direct Anthropic ---
ANTHROPIC_API_KEY=
# Provider-native Cloudflare AI Gateway endpoint for Anthropic.
# https://gateway.ai.cloudflare.com/v1/<account_id>/<gateway_id>/anthropic
AI_GATEWAY_URL=
# Defaults to claude-opus-4-8; set claude-haiku-4-5 for cheaper reviews.
AI_MODEL=
