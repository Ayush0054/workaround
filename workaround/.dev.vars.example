# Copy to .dev.vars for local development (never commit .dev.vars).
# In production set these with: npx wrangler secret put <NAME>

# GitHub App (recommended) or OAuth App credentials — see README for setup.
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# 32+ random chars; generate with: openssl rand -base64 32
SESSION_SECRET=change_me_to_a_long_random_string

# --- Optional: AI review ---
# Leave ANTHROPIC_API_KEY empty to run heuristics-only.
ANTHROPIC_API_KEY=
# Cloudflare AI Gateway endpoint for Anthropic (recommended: caching + spend limits).
# https://gateway.ai.cloudflare.com/v1/<account_id>/<gateway_id>/anthropic
AI_GATEWAY_URL=
# Defaults to claude-opus-4-8; set claude-haiku-4-5 for cheaper reviews.
AI_MODEL=
